{
  "name": "quinoa-pet-manager",
  "version": "3.2.13",
  "description": "Quality of life tools for Magic Garden including crop tracking, mutation reminders, and inventory management",
  "main": "dist/userscript.js",
  "scripts": {
    "dev": "vite build --watch",
    "build": "npm run sync-version && npm run build:bundle && npm run build:userscript",
    "sync-version": "node scripts/sync-version.js",
    "build:bundle": "vite build",
    "build:userscript": "node scripts/build-userscript.js",
    "build:dist": "npm run build",
    "scrape-game-data": "node scripts/scrape-game-data.js",
    "parse-discord-html": "node --max-old-space-size=4096 scripts/parse-discord-html.js",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "postinstall": "echo Cross-platform setup complete!",
    "check:i18n": "node scripts/check-i18n-keys.mjs"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/tampermonkey": "^4.0.10",
    "jsdom": "^27.2.0",
    "jszip": "^3.10.1",
    "terser": "^5.26.0",
    "typescript": "^5.3.0",
    "vite": "^7.1.12",
    "vite-plugin-dts": "^4.5.4"
  },
  "license": "MIT",
  "keywords": ["magic-garden", "userscript", "tampermonkey", "pet-manager", "game-mod"],
  "dependencies": {
    "@h00w/basis-universal-transcoder": "^2.0.5"
  }
}
